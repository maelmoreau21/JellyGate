# =============================================================================
# JellyGate — Configuration
# =============================================================================
# Copiez ce fichier en .env et remplissez les valeurs.
# Les variables marquées [REQUIS] sont obligatoires au démarrage.
# Les variables marquées [OPTIONNEL] ont une valeur par défaut ou sont ignorées si vides.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────

# [OPTIONNEL] Port d'écoute HTTP (défaut: 8097)
JELLYGATE_PORT=8097

# [OPTIONNEL] URL publique de JellyGate (utilisée dans les emails et les liens d'invitation)
JELLYGATE_BASE_URL=http://localhost:8097

# [OPTIONNEL] Répertoire de stockage des données (SQLite, etc.) — en Docker: /data
JELLYGATE_DATA_DIR=/data

# [REQUIS] Clé secrète pour signer les cookies de session (minimum 32 caractères)
# Générer avec : openssl rand -hex 32
JELLYGATE_SECRET_KEY=

# [OPTIONNEL] Langue par défaut de l'interface (fr ou en, défaut: fr)
JELLYGATE_DEFAULT_LANG=fr

# ─── Jellyfin ────────────────────────────────────────────────────────────────

# [REQUIS] URL de votre serveur Jellyfin (ex: http://192.168.1.10:8096)
JELLYFIN_URL=

# [REQUIS] Clé API Jellyfin (Dashboard → API Keys → créer une clé pour "JellyGate")
JELLYFIN_API_KEY=

# ─── LDAP / Synology Active Directory ────────────────────────────────────────

# [REQUIS] Hostname ou IP du serveur LDAP (ex: nas.local ou 192.168.1.5)
LDAP_HOST=

# [OPTIONNEL] Port LDAP (défaut: 636 pour LDAPS)
LDAP_PORT=636

# [OPTIONNEL] Activer TLS/LDAPS (défaut: true)
LDAP_USE_TLS=true

# [OPTIONNEL] Ignorer la vérification du certificat TLS (défaut: false)
# Mettre à true uniquement si vous utilisez un certificat auto-signé
LDAP_SKIP_VERIFY=false

# [REQUIS] DN du compte de service pour se lier à l'annuaire
# Synology AD : CN=admin,CN=Users,DC=example,DC=com
LDAP_BIND_DN=

# [REQUIS] Mot de passe du compte de service LDAP
LDAP_BIND_PASSWORD=

# [REQUIS] Base DN de l'annuaire (ex: DC=example,DC=com)
LDAP_BASE_DN=

# [OPTIONNEL] OU où créer les nouveaux utilisateurs (défaut: CN=Users)
LDAP_USER_OU=CN=Users

# [OPTIONNEL] Groupe AD auquel ajouter les nouveaux utilisateurs (DN complet)
# Si vide, les utilisateurs ne sont ajoutés à aucun groupe
LDAP_USER_GROUP=

# [REQUIS] Domaine AD pour le userPrincipalName (ex: example.com)
LDAP_DOMAIN=

# ─── SMTP (Email) ────────────────────────────────────────────────────────────

# [REQUIS] Serveur SMTP (ex: smtp.gmail.com, smtp.mailgun.org)
SMTP_HOST=

# [OPTIONNEL] Port SMTP (défaut: 587 pour STARTTLS, 465 pour TLS implicite)
SMTP_PORT=587

# [REQUIS] Nom d'utilisateur SMTP
SMTP_USERNAME=

# [REQUIS] Mot de passe SMTP (ou mot de passe d'application pour Gmail)
SMTP_PASSWORD=

# [REQUIS] Adresse email de l'expéditeur (ex: noreply@example.com)
SMTP_FROM=

# [OPTIONNEL] Activer STARTTLS/TLS (défaut: true)
SMTP_TLS=true

# ─── Webhooks (optionnels) ───────────────────────────────────────────────────
# Si une variable est vide, la plateforme correspondante est ignorée.

# Discord — URL du webhook (Paramètres du serveur → Intégrations → Webhooks)
WEBHOOK_DISCORD_URL=

# Telegram — Token du bot (obtenu via @BotFather)
WEBHOOK_TELEGRAM_TOKEN=
# Telegram — ID du chat ou du groupe (obtenu via @userinfobot)
WEBHOOK_TELEGRAM_CHAT_ID=

# Matrix — URL du serveur homeserver (ex: https://matrix.example.com)
WEBHOOK_MATRIX_URL=
# Matrix — ID de la room (ex: !abcdef:example.com)
WEBHOOK_MATRIX_ROOM_ID=
# Matrix — Access token du bot
WEBHOOK_MATRIX_TOKEN=
