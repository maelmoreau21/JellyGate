# =============================================================================
# JellyGate — Configuration
# =============================================================================
# Copiez ce fichier en .env et remplissez les valeurs.
#
# IMPORTANT : Seuls les paramètres essentiels au démarrage sont ici.
# La configuration LDAP, SMTP et Webhooks se fait désormais depuis
# l'interface d'administration (stockée en base SQL).
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────

# [OPTIONNEL] Port d'écoute HTTP (défaut: 8097)
JELLYGATE_PORT=8097

# [OPTIONNEL] URL publique de JellyGate (utilisée dans les emails et les liens d'invitation)
JELLYGATE_BASE_URL=http://localhost:8097

# [OPTIONNEL] Répertoire de stockage des données (SQLite, etc.) — en Docker: /data
JELLYGATE_DATA_DIR=/data

# [OPTIONNEL] Type de base SQL: sqlite (défaut) ou postgres
DB_TYPE=sqlite

# [OPTIONNEL] Paramètres PostgreSQL (utilisés uniquement si DB_TYPE=postgres)
DB_HOST=postgres
DB_PORT=5432
DB_USER=jellygate
DB_PASSWORD=jellygate
DB_NAME=jellygate
DB_SSLMODE=disable

# [REQUIS] Clé secrète pour signer les cookies de session (minimum 32 caractères)
# Générer avec : openssl rand -hex 32
JELLYGATE_SECRET_KEY=

# [OPTIONNEL] Langue par défaut de l'interface (fr ou en, défaut: fr)
JELLYGATE_DEFAULT_LANG=fr

# ─── Jellyfin ────────────────────────────────────────────────────────────────

# [REQUIS] URL de votre serveur Jellyfin (ex: http://192.168.1.10:8096)
JELLYFIN_URL=

# [REQUIS] Clé API Jellyfin (Dashboard → API Keys → créer une clé pour "JellyGate")
JELLYFIN_API_KEY=

# ─── Intégrations tierces optionnelles (provisionnement) ───────────────────

# [OPTIONNEL] URL Jellyseerr (ex: http://192.168.1.20:5055)
JELLYSEERR_URL=

# [OPTIONNEL] Clé API Jellyseerr
JELLYSEERR_API_KEY=

# [OPTIONNEL] URL Ombi (ex: http://192.168.1.21:3579)
OMBI_URL=

# [OPTIONNEL] Clé API Ombi
OMBI_API_KEY=

# [OPTIONNEL] URL publique JellyTulli (raccourcis UI + templates emails)
JELLYTULLI_URL=
