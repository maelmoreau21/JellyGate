# =============================================================================
# JellyGate — Configuration Example
# =============================================================================
# Copiez ce fichier en .env et remplissez les valeurs.
#
# IMPORTANT : Seuls les paramètres essentiels au démarrage sont ici.
# La configuration LDAP, SMTP et Webhooks se fait désormais depuis
# l'interface d'administration (stockée en base de données).
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────

# Port d'écoute HTTP (défaut: 8097)
JELLYGATE_PORT=8097

# URL publique de JellyGate (utilisée dans les emails et les liens d'invitation)
# Exemple: https://jellygate.exemple.com
JELLYGATE_BASE_URL=http://localhost:8097

# Répertoire de stockage des données (SQLite, config, etc.) — en Docker: /data
JELLYGATE_DATA_DIR=/data

# Type de base de données: sqlite (défaut) ou postgres
DB_TYPE=sqlite

# Paramètres PostgreSQL (utilisés uniquement si DB_TYPE=postgres)
DB_HOST=postgres
DB_PORT=5432
DB_USER=jellygate
DB_PASSWORD=jellygate
DB_NAME=jellygate
DB_SSLMODE=disable

# [REQUIS] Clé secrète pour signer les cookies de session (minimum 32 caractères)
# Générer avec : openssl rand -hex 32
JELLYGATE_SECRET_KEY=

# Langue par défaut de l'interface (fr, en, de, es, it, nl, pl, pt-br, ru, zh)
JELLYGATE_DEFAULT_LANG=fr

# Mode debug (affiche plus de logs, défaut: false)
JELLYGATE_DEBUG=false
JELLYGATE_TRUST_PROXY_HEADERS=false
JELLYGATE_ALLOW_INSECURE_LDAP_SKIP_VERIFY=false

# ─── Jellyfin ────────────────────────────────────────────────────────────────

# [REQUIS] URL de votre serveur Jellyfin (ex: http://192.168.1.10:8096)
JELLYFIN_URL=

# [REQUIS] Clé API Jellyfin (Dashboard → API Keys)
JELLYFIN_API_KEY=

# ─── Intégrations Tierces (Optionnel) ──────────────────────────────────────

# Jellyseerr (Provisionnement automatique)
JELLYSEERR_URL=
JELLYSEERR_API_KEY=

# Ombi (Alternative à Jellyseerr)
OMBI_URL=
OMBI_API_KEY=

# JellyTulli (Raccourcis UI et templates e-mails)
JELLYTULLI_URL=
